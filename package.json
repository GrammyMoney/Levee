  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "prettier": "^3.8.4",
    "tailwindcss": "^4",
    "typescript": "~5.8",
    "vitest": "^3.2.6"
  },
  "packageManager": "pnpm@10.26.1"

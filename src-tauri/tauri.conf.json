{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Levee",
  "version": "0.1.0",
  "identifier": "com.levee.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Levee",
        "width": 1280,
        "height": 720,
        "minWidth": 640,
        "minHeight": 360,
        "decorations": true,
        "transparent": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "GrammyMoney",
    "category": "Video",
    "shortDescription": "Proxy video player and Suite pre-cache manager",
    "longDescription": "Levee is a lightweight video player for media professionals. Generate and toggle proxy files, manage Suite pre-cache from within the player, and inspect technical metadata — all from a single focused UI.",
    "fileAssociations": [
      {
        "ext": ["mp4", "mov", "mkv", "avi", "webm", "mxf"],
        "name": "Video",
        "description": "Video file",
        "icon": "icons/icon.ico"
      },
      {
        "ext": ["mp3", "wav", "aiff", "aac", "flac", "ogg"],
        "name": "Audio",
        "description": "Audio file",
        "icon": "icons/icon.ico"
      }
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"],
        "startMenuFolder": "Levee",
        "displayLanguageSelector": false
      }
    },
    "externalBin": ["binaries/ffprobe"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
